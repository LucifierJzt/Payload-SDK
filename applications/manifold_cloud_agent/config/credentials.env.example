# Copy this file to credentials.env on the Manifold only, then set mode 0600.
# Do not commit credentials.env or paste these values into chat/logs.
MANIFOLD_AGENT_APP_NAME=replace_with_registered_app_name
MANIFOLD_AGENT_APP_ID=replace_with_registered_app_id
MANIFOLD_AGENT_APP_KEY=replace_with_registered_app_key
MANIFOLD_AGENT_APP_LICENSE=replace_with_registered_app_license
MANIFOLD_AGENT_DEVELOPER_ACCOUNT=replace_with_registered_developer_account
MANIFOLD_AGENT_BAUD_RATE=460800
